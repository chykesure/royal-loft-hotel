generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  relationMode = "prisma"
  url      = env("DATABASE_URL")
}

// ============ AUTH & USERS ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  role          String    @default("staff") // super_admin, manager, front_desk, housekeeping, accountant, auditor, staff
  department    String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  roles         Role[]
  staffProfile  StaffProfile?
  staffAttendances     StaffAttendance[]
  auditLogs     AuditLog[]
  maintenanceRequests MaintenanceRequest[]
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  device    String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============ ROLES & PERMISSIONS ============

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String   @id @default(cuid())
  module      String   // dashboard, rooms, reservations, guests, billing, accounts, staff, inventory, reports, rules, security, cloud, settings, front_desk
  action      String   // view, create, edit, delete, export
  fieldLevel  String?  // optional field-level restriction
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ============ ROOMS ============

model RoomType {
  id          String   @id @default(cuid())
  name        String   // Standard, Deluxe, Suite, Presidential
  description String?
  baseRate    Float    // base price per night
  maxOccupancy Int     // max guests
  amenities   String?  // JSON array of amenities
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms Room[]
  roomPricing RoomPricing[]
}

model Room {
  id          String   @id @default(cuid())
  roomNumber  String   @unique
  floor       Int
  roomTypeId  String
  status      String   @default("available") // available, occupied, housekeeping, maintenance, reserved, out_of_service
  currentCondition String? // good, needs_repair, renovation
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roomType       RoomType        @relation(fields: [roomTypeId], references: [id])
  reservations  Reservation[]
  housekeeping  HousekeepingTask[]
  maintenanceRequests MaintenanceRequest[]
  iotDevices    IoTDevice[]
}

model RoomPricing {
  id          String   @id @default(cuid())
  roomTypeId  String
  season      String   @default("regular") // low, regular, peak, holiday
  startDate   DateTime?
  endDate     DateTime?
  price       Float
  isAiSuggested Boolean @default(false) // set by dynamic pricing engine
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@index([roomTypeId])
}

// ============ GUESTS ============

model Guest {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String
  address       String?
  city          String?
  state         String?
  country       String    @default("Nigeria")
  idType        String?   // NIN, Passport, Drivers License, Voters Card
  idNumber      String?
  idPhoto       String?   // path to uploaded ID
  dateOfBirth   DateTime?
  gender        String?   // male, female, other
  nationality   String?
  company       String?
  loyaltyTier   String    @default("none") // none, silver, gold, platinum
  loyaltyPoints Int       @default(0)
  isBlacklisted Boolean   @default(false)
  blacklistReason String?
  vip           Boolean   @default(false)
  preferences   String?   // JSON - pillow type, dietary, etc.
  notes         String?
  totalStays    Int       @default(0)
  totalSpent    Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  reservations Reservation[]
  feedbacks     GuestFeedback[]
  bills         Bill[]
  chatbotConversations ChatbotConversation[]
}

// ============ RESERVATIONS ============

model Reservation {
  id               String          @id @default(cuid())
  confirmationCode String          @unique
  guestId          String
  roomId           String
  checkIn          DateTime
  checkOut         DateTime
  status           String          @default("confirmed")
  source           String          @default("walk_in")
  adults           Int             @default(1)
  children         Int             @default(0)
  specialRequests  String?
  roomRate         Float
  totalAmount      Float
  paidAmount       Float           @default(0)
  groupCode        String?
  notes            String?
  createdBy        String?
  cancelledAt      DateTime?
  cancelReason     String?
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  bill             Bill?
  feedbacks        GuestFeedback[]
  room             Room            @relation(fields: [roomId], references: [id])
  guest            Guest           @relation(fields: [guestId], references: [id])

  @@index([groupCode])
}

// ============ BILLING ============

model Bill {
  id              String    @id @default(cuid())
  reservationId   String?   @unique
  guestId         String
  roomCharges     Float     @default(0)
  foodCharges     Float     @default(0)
  barCharges      Float     @default(0)
  spaCharges      Float     @default(0)
  laundryCharges  Float     @default(0)
  otherCharges    Float     @default(0)
  taxAmount       Float     @default(0)
  discountAmount  Float     @default(0)
  totalAmount     Float
  paidAmount      Float     @default(0)
  balanceAmount   Float
  status          String    @default("open") // open, partially_paid, paid, cancelled
  paymentMethod   String?   // cash, pos, bank_transfer, opay, palmpay, moniepoint
  paymentRef      String?
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reservation Reservation?  @relation(fields: [reservationId], references: [id])
  guest       Guest         @relation(fields: [guestId], references: [id])
  payments    Payment[]
  invoices    Invoice[]
}

model Payment {
  id              String    @id @default(cuid())
  billId          String
  amount          Float
  paymentMethod   String    // cash, pos, bank_transfer, opay, palmpay, moniepoint
  paymentRef      String?
  notes           String?
  createdBy       String?
  createdAt       DateTime  @default(now())

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

// ============ HOUSEKEEPING ============

model HousekeepingTask {
  id            String    @id @default(cuid())
  roomId        String
  assignedTo    String?   // User ID
  type          String    @default("cleaning") // cleaning, deep_cleaning, maintenance_check, turndown
  priority      String    @default("normal") // low, normal, high, urgent
  status        String    @default("pending") // pending, in_progress, completed, skipped
  scheduledAt   DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  notes         String?
  createdBy     String?
  autoAssigned  Boolean   @default(false) // true if auto-assigned by system
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  room Room @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@index([assignedTo])
}

// ============ MAINTENANCE ============

model MaintenanceRequest {
  id            String    @id @default(cuid())
  roomId        String
  reportedBy    String?   // User ID
  assignedTo    String?
  title         String
  description   String
  priority      String    @default("normal") // low, normal, high, urgent
  status        String    @default("reported") // reported, in_progress, resolved, closed
  category      String    // plumbing, electrical, hvac, furniture, appliance, cosmetic, other
  scheduledAt   DateTime?
  startedAt     DateTime?
  resolvedAt    DateTime?
  cost          Float?
  vendorName    String?
  vendorContact String?
  notes         String?
  guestVisible  Boolean   @default(true) // whether guest can see the status
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  room Room @relation(fields: [roomId], references: [id])
  reporter User? @relation(fields: [reportedBy], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([assignedTo])
}

// ============ IoT DEVICES ============

model IoTDevice {
  id          String   @id @default(cuid())
  roomId      String
  deviceType  String   // thermostat, light, tv, lock, curtain
  deviceName  String
  status      String   @default("online") // online, offline, maintenance
  lastReading String?  // JSON - latest sensor data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

// ============ STAFF & PAYROLL ============

model StaffProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  employeeId    String    @unique
  department    String    // front_desk, housekeeping, kitchen, security, maintenance, management, accounts
  position      String
  baseSalary    Float
  startDate     DateTime
  endDate       DateTime?
  status        String    @default("active") // active, on_leave, suspended, terminated
  bankName      String?
  bankAccount   String?
  emergencyContact String?
  emergencyPhone String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  payrollRecords PayrollRecord[]
  attendances    Attendance[]
}

model Attendance {
  id         String    @id @default(cuid())
  staffId    String
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  hoursWorked Float?
  status     String    @default("absent") // present, absent, half_day, on_leave, holiday
  notes      String?
  createdAt  DateTime  @default(now())

  staff StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, date])
}

model PayrollRecord {
  id            String    @id @default(cuid())
  staffId       String
  period        String    // e.g., "2026-04"
  basicSalary   Float
  overtimePay   Float     @default(0)
  bonus         Float     @default(0)
  deductions    Float     @default(0) // PAYE, pension, etc.
  taxAmount     Float     @default(0)
  netPay        Float
  status        String    @default("pending") // pending, processed, paid
  paidAt        DateTime?
  processedBy   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  staff StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, period])
}

// ============ INVENTORY ============

model InventoryItem {
  id              String    @id @default(cuid())
  name            String
  category        String    // housekeeping, kitchen, bar, maintenance, office, front_desk
  description     String?
  unit            String    // pieces, liters, kg, packs, rolls, boxes
  currentQuantity Float     @default(0)
  minimumLevel    Float     @default(0)
  reorderQuantity Float?
  unitCost        Float?
  supplier        String?
  location        String?   // where stored
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stockMovements StockMovement[]
}

model StockMovement {
  id          String    @id @default(cuid())
  itemId      String
  type        String    // in, out, adjustment, waste
  quantity    Float
  unitCost    Float?
  reference   String?   // PO number or reason
  performedBy String?   // User ID
  notes       String?
  createdAt   DateTime  @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
}

// ============ HOTEL RULES ============

model HotelPolicy {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // checkin_checkout, cancellation, payment, conduct, pets, children, smoking, other
  isActive    Boolean  @default(true)
  displayToGuest Boolean @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ CLOUD STORAGE ============

model CloudFile {
  id          String   @id @default(cuid())
  name        String
  originalName String
  mimeType    String
  size        Int
  path        String
  category    String?  // contracts, licenses, guest_ids, receipts, invoices, policies, reports, other
  accessLevel String   @default("admin") // admin, manager, accountant, all_staff
  uploadedBy  String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// ============ NOTIFICATIONS ============

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  message     String
  type        String   @default("info") // info, warning, error, success, security
  category    String?  // reservation, billing, maintenance, security, system, housekeeping
  isRead      Boolean  @default(false)
  link        String?  // optional link to related record
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
}

// ============ AUDIT LOGS ============

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  userName    String?
  action      String   // login, logout, create, read, update, delete, export, access_denied
  module      String   // which module
  recordId    String?  // ID of the record affected
  details     String?  // JSON with changes
  ipAddress   String?
  userAgent   String?
  status      String   @default("success") // success, failure, denied
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([createdAt])
}

// ============ GUEST FEEDBACK ============

model GuestFeedback {
  id            String    @id @default(cuid())
  guest         Guest?       @relation(fields: [guestId], references: [id], onDelete: SetNull)
  reservation   Reservation?  @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  guestId       String?
  reservationId String?
  rating        Int       // 1-5
  category      String?   // room, service, food, cleanliness, amenities, overall
  comment       String?
  isResolved    Boolean   @default(false)
  respondedBy   String?
  response      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([guestId])
  @@index([rating])
}



// ============ DEMAND FORECAST ============

model DemandForecast {
  id          String   @id @default(cuid())
  date        DateTime
  predictedOccupancy Float
  predictedRevenue   Float
  confidenceScore   Float?
  factors     String?  // JSON - events, season, holidays, etc.
  createdAt   DateTime @default(now())

  @@unique([date])
}

// ============ DYNAMIC PRICING LOG ============

model PricingSuggestion {
  id          String   @id @default(cuid())
  roomTypeId  String
  suggestedPrice Float
  currentPrice   Float
  factors     String?  // JSON - demand, season, events, etc.
  applied     Boolean  @default(false)
  appliedBy   String?
  createdAt   DateTime @default(now())

  @@index([roomTypeId])
  @@index([createdAt])
}

// ============ SECURITY ALERTS ============

model SecurityAlert {
  id          String   @id @default(cuid())
  type        String   // failed_login, suspicious_device, unauthorized_access, data_export, brute_force
  severity    String   @default("medium") // low, medium, high, critical
  userId      String?
  ipAddress   String?
  details     String?
  isResolved  Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([type, isResolved])
  @@index([createdAt])
}

// ============ AI CHATBOT LOGS ============

model ChatbotConversation {
  id          String   @id @default(cuid())
  guest       Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  guestId     String?
  sessionId   String
  message     String
  response    String
  intent      String?  // checkout_time, breakfast, amenities, directions, booking, other
  createdAt   DateTime @default(now())

  @@index([sessionId])
}

// ============ ROLE MODULE ACCESS (Dynamic sidebar visibility) ============

model RoleModuleAccess {
  id        String   @id @default(cuid())
  role      String   @unique // e.g. manager, front_desk, housekeeping, accountant, auditor, staff
  modules   String   // JSON array of module keys this role can see, e.g. ["dashboard","rooms","billing"]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ============ EXPENSES ============
model Expense {
  id            String    @id @default(cuid())
  description   String
  category      String
  amount        Float
  paymentMethod String    @default("cash")
  vendor        String?
  reference     String?
  expenseDate   DateTime
  notes         String?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([category])
  @@index([expenseDate])
}


model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  name        String?
  description String?
  category    String?
  amount      Float?
  kitchen     Float?
  hotel       Float?
  beverages   Float?
  total       Float    @default(0)
  vendor      String?
  reference   String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
}

model StaffAttendance {
  id        String   @id @default(cuid())
  staffId   String
  date      DateTime @default(now())
  status    String
  note      String?
  createdAt DateTime @default(now())
  staff     User     @relation(fields: [staffId], references: [id])
  @@unique([staffId, date])
}


// ============ INVOICES ============

model Invoice {
  id               String    @id @default(cuid())
  invoiceNumber    String    @unique
  billId           String
  reservationId    String?
  guestId          String
  guestName        String
  guestPhone       String
  guestEmail       String?
  guestAddress     String?
  hotelName        String
  hotelAddress     String?
  hotelPhone       String?
  hotelEmail       String?
  hotelWebsite     String?
  confirmationCode String?
  groupCode        String?
  roomNumber       String?
  roomType         String?
  roomDetails      String?
  checkIn          DateTime?
  checkOut         DateTime?
  nights           Int       @default(1)
  roomRate         Float     @default(0)
  numRooms         Int       @default(1)
  roomCharges      Float     @default(0)
  foodCharges      Float     @default(0)
  barCharges       Float     @default(0)
  spaCharges       Float     @default(0)
  laundryCharges   Float     @default(0)
  otherCharges     Float     @default(0)
  subtotal         Float
  taxRate          Float     @default(7.5)
  taxAmount        Float     @default(0)
  discountAmount   Float     @default(0)
  totalAmount      Float
  paidAmount       Float     @default(0)
  balanceAmount    Float     @default(0)
  paymentMethod    String?
  paymentRef       String?
  status           String    @default("sent")
  notes            String?
  issuedAt         DateTime  @default(now())
  dueAt            DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  bill             Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([guestId])
  @@index([issuedAt])
  @@index([groupCode])
}

// ============ HOTEL SETTINGS ============

model HotelSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String
  label     String
  type      String   @default("text")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Backup {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("manual")
  status        String   @default("pending")
  sizeBytes     Int      @default(0)
  tablesCount   Int      @default(0)
  recordsCount  Int      @default(0)
  storagePath   String?
  data          String?
  createdBy     String?
  createdByName String?
  error         String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
}
